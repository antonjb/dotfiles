// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "diff_view_style": "split",
  "indent_guides": {
		"background_coloring": "disabled",
		"coloring": "indent_aware"
	},
	"toolbar": {
		"breadcrumbs": true
	},
	"terminal": {
		"shell": "system"
	},
	"project_panel": {
		"default_width": 240.0,
		"dock": "left"
	},
	"title_bar": {
		"show_user_menu": true,
		"show_sign_in": false,
		"show_branch_icon": true
	},
	"tab_bar": {
		"show_pinned_tabs_in_separate_row": false
	},
	"tabs": {
		"file_icons": true,
		"git_status": true
	},
	"languages": {
		"Astro": { "formatter": { "language_server": { "name": "biome" } } },
		"CSS": { "formatter": { "language_server": { "name": "biome" } } },
		"Git Commit": {
			"hard_tabs": false,
   "soft_wrap": "none",
			"preferred_line_length": 80
		},
		"HTML": { "formatter": { "language_server": { "name": "biome" } } },
		"JSON": { "formatter": { "language_server": { "name": "biome" } } },
		"JSONC": { "formatter": { "language_server": { "name": "biome" } } },
		"JSX": { "formatter": { "language_server": { "name": "biome" } } },
		"JavaScript": { "formatter": { "language_server": { "name": "biome" } } },
		"TSX": { "formatter": { "language_server": { "name": "biome" } } },
		"TypeScript": { "formatter": { "language_server": { "name": "biome" } } }
	},
	"remove_trailing_whitespace_on_save": true,
	"scrollbar": {
		"show": "always"
	},
	"base_keymap": "VSCode",
	"agent": {
		"dock": "right",
  "message_editor_min_lines": 6,
		"favorite_models": [],
		"model_parameters": [],
		"enable_feedback": false
	},
	"agent_buffer_font_size": 15.0,
	"buffer_line_height": "comfortable",
	"ui_font_weight": 400.0,
	"agent_servers": {
		"gemini": {
			"type": "registry"
		},
		"claude-acp": {
			"type": "registry"
		}
	},
	"telemetry": {
		"diagnostics": false,
		"metrics": false
	},
	"icon_theme": "Zed (Default)",
	"ui_font_size": 18.0,
	"buffer_font_size": 15.0,
	"theme": "One Dark",
	"lsp": {
		"biome": {
			"settings": {
				"require_config_file": true
			}
		}
	}
}
